{
  "name": "vibe-code-flashcard-app",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5"
  },
  "lint-staged": {
    "**/*.{js,jsx}": "eslint --fix"
  }
}
